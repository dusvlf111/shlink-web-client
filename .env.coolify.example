################################################################################
# Shlink + PocketBase 통합 환경 설정
# 개발(로컬) 및 Coolify 프로덕션 배포 모두에서 사용 가능한 설정 파일
#
# 사용법:
#   개발: cp .env.coolify.example .env.local
#   Coolify: Coolify 대시보드 → Environment Variables에 아래 변수들을 설정
################################################################################

################################################################################
# 1. 환경 모드
################################################################################
NODE_ENV=production

################################################################################
# 2. 데이터베이스 설정 (PostgreSQL)
# Coolify에서 자동으로 DATABASE_URL이 제공되는 경우 이 항목은 불필요합니다.
# 선택사항: SERVICE_PASSWORD_POSTGRES만 설정하면 docker-compose.yml에서 참조합니다.
################################################################################

# PostgreSQL 데이터베이스 비밀번호 (docker-compose에서 사용)
# 강력한 비밀번호로 변경 필수 (최소 16자, 특수문자 포함)
SERVICE_PASSWORD_POSTGRES=SecurePostgresPassword123!@#Shlink2024

################################################################################
# 3. Shlink 백엔드 설정
################################################################################

# Shlink API 키 (Base64 인코딩)
# 생성 방법:
#   Linux/Mac: echo -n "your-random-secret-key-min-16-chars" | base64
#   Windows: certutil -encode input.txt output.txt
# 예시: YW91ci1zZWNyZXQta2V5LWhlcmUtaXMtc3VwZXItc2VjdXJl
SERVICE_BASE64_SHLINKAPIKEY=YW91ci1zZWNyZXQta2V5LWhlcmUtaXMtc3VwZXItc2VjdXJl

# Shlink 도메인 (FQDN - Fully Qualified Domain Name)
# 예: shlink.example.com 또는 shorten.company.com
SERVICE_FQDN_SHLINK=shlink.example.com

# HTTPS 활성화 여부 (Shlink 서버)
# false: HTTP만 사용 (Coolify SSL 미사용)
# true: HTTPS 사용 (Coolify SSL 또는 리버스 프록시 사용)
IS_HTTPS_ENABLED=false

# Shlink 백엔드 URL (서비스 간 통신)
# Coolify: http://shlink:8080 (자동으로 SERVICE_FQDN_SHLINK에서 생성)
# 로컬: http://localhost:8080
SERVICE_URL_SHLINK_8080=http://shlink:8080

# 기본 단축 URL 모드 (path 또는 domain)
# path: example.com/s/abc123 (권장)
# domain: short.example.com/abc123
SHLINK_SHORT_URL_MODE=path

# 방문 통계 Webhook 활성화
SHLINK_VISITS_WEBHOOKS=true

# 링크 제목 자동 수집
SHLINK_RESOLVE_TITLE=true

# 기본 단축 URL 리다이렉트 상태 코드 (302 또는 301)
SHLINK_DEFAULT_SHORT_CODE_LENGTH=6

################################################################################
# 4. PocketBase 설정 (인증 및 사용자 관리)
################################################################################

# PocketBase 도메인
SERVICE_FQDN_POCKETBASE=pocketbase.example.com

# PocketBase 백엔드 URL (웹에서 사용)
# Coolify: http://pocketbase:8090 (자동으로 SERVICE_FQDN_POCKETBASE에서 생성)
# 로컬: http://localhost:8090
SERVICE_URL_POCKETBASE_8090=http://pocketbase:8090

# 웹 클라이언트에서 사용하는 PocketBase URL
VITE_POCKETBASE_URL=http://pocketbase:8090

################################################################################
# 5. Shlink Web Client 설정
################################################################################

# Shlink Web Client 도메인
SERVICE_FQDN_SHLINKWEB=shlink-web.example.com

# Shlink Web 백엔드 URL (외부)
# Coolify: http://shlink-web:8080 (자동으로 SERVICE_FQDN_SHLINKWEB에서 생성)
# 로컬: http://localhost:3000
SERVICE_URL_SHLINKWEB_8080=http://shlink-web:8080

# Shlink API 키 (웹 클라이언트에서 사용)
# SERVICE_BASE64_SHLINKAPIKEY와 동일한 값
SHLINK_SERVER_API_KEY=YW91ci1zZWNyZXQta2V5LWhlcmUtaXMtc3VwZXItc2VjdXJl

# Shlink 서버 URL (웹 클라이언트에서 사용)
# Coolify: http://shlink:8080
# 로컬: http://localhost:8080
SHLINK_SERVER_URL=http://shlink:8080

# 웹 앱 Base URL (선택사항)
# 루트가 아닌 서브 경로에 배포되는 경우 설정
# 예: /shlink/ 또는 /app/shlink/
# VITE_BASE_URL=/

################################################################################
# 6. 선택사항: 모니터링 및 분석
################################################################################

# Sentry 오류 추적 (선택사항)
# https://sentry.io에서 프로젝트 생성 후 DSN 입력
# VITE_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/123456

# Google Analytics (선택사항)
# Google Analytics 4 Measurement ID
# VITE_GA_ID=G-XXXXXXXXXX

# API 타임아웃 (밀리초, 기본값: 30000)
# VITE_API_TIMEOUT=30000

################################################################################
# 7. 선택사항: 기타 설정
################################################################################

# 언어 설정 (ko, en, es, pt, fr, it, etc.)
# VITE_LOCALE=ko

# 테마 (light, dark, auto)
# VITE_THEME=auto

# 로그 레벨 (debug, info, warn, error)
# VITE_LOG_LEVEL=info
